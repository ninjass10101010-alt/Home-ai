#!/usr/bin/expect -f
set timeout 10
set user [lindex $argv 0]
set password [lindex $argv 1]
set host [lindex $argv 2]

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect {
    "*assword:*" {
        send "$password\r"
    }
    timeout {
        puts "Timeout waiting for password prompt"
        exit 1
    }
}
expect "*#"
send "mkdir -p /share/Container/pocketbase\r"
expect "*#"
exit 0
